<?xml version="1.0" encoding="utf-8"?>
<hibernate-configuration>
    <session-factory>
        <property name="hibernate.dialect">org.hibernate.dialect.PostgreSQL82Dialect</property>
        <property name="hibernate.connection.driver_class">org.postgresql.Driver</property>
        <property name="hibernate.connection.username">hospital_user</property>
        <property name="hibernate.connection.password">12345</property>
        <property name="hibernate.connection.url">jdbc:postgresql://localhost:8081/hospital_db</property>
        <property name="hbm2ddl.auto">update</property>
        <property name="show_sql">true</property>

        <!-- MAPPINGS -->
        <mapping class="dasturlash.uz.entity.Hospital"/>
        <mapping class="dasturlash.uz.entity.Address"/>
        <mapping class="dasturlash.uz.entity.EmergencyRoom"/>
        <mapping class="dasturlash.uz.entity.PhoneNumber"/>
        <mapping class="dasturlash.uz.entity.Transport"/>
        <mapping class="dasturlash.uz.entity.Employee"/>
        <mapping class="dasturlash.uz.entity.Driver"/>
        <mapping class="dasturlash.uz.entity.WorkShift"/>
        <mapping class="dasturlash.uz.entity.EMS"/>

    </session-factory>

</hibernate-configuration>
